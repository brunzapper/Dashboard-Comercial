# Versão: 1.0 | Data: 04/07/2026
# Referência das variáveis de ambiente. NÃO coloque valores aqui.
# Os valores reais vivem exclusivamente nas Environment Variables da Vercel
# (marcadas para Production, Preview e Development) e no painel do Supabase.
# Este arquivo serve apenas como checklist da lista a configurar na Vercel.

# --- Supabase (obrigatórias) ---
# URL do projeto Supabase (pública). Ex.: https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Chave anônima (pública) do Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SECRETA — só no servidor). Bypassa RLS; usada em sync/admin.
SUPABASE_SERVICE_ROLE_KEY=

# --- Bitrix24 (Fase 2) ---
# Webhook de ENTRADA do Bitrix. Formato:
# https://b24-XXXX.bitrix24.com.br/rest/{user}/{token}/
BITRIX_WEBHOOK_URL=
# Token do webhook de SAÍDA do Bitrix (validação dos eventos ONCRMDEAL*/ONCRMLEAD*).
BITRIX_OUTBOUND_TOKEN=

# --- Segredo compartilhado das rotas de sync (Fases 2 e 3) ---
# Protege /api/sync/* (backfill, reconcile, sheets).
SYNC_SECRET=

# --- Google Sheets (Fase 3, Opção B — leitura direta; atrás de flag) ---
# Deixe em branco enquanto usar a Opção A (push via Apps Script).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
SHEET_ID_ESTUDO_FECHAMENTOS=
SHEET_ID_INBOUND_ZAPPER=
