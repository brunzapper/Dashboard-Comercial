# Versão: 1.0 | Data: 04/07/2026
# Referência das variáveis de ambiente. NÃO coloque valores aqui.
# Os valores reais vivem exclusivamente nas Environment Variables da Vercel
# (marcadas para Production, Preview e Development) e no painel do Supabase.
# Este arquivo serve apenas como checklist da lista a configurar na Vercel.

# --- Supabase (obrigatórias) ---
# URL do projeto Supabase (pública). Ex.: https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Chave anônima (pública) do Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SECRETA — só no servidor). Bypassa RLS; usada em sync/admin.
SUPABASE_SERVICE_ROLE_KEY=

# --- Bitrix24 (Fase 2) ---
# Webhook de ENTRADA do Bitrix (API REST). OBRIGATÓRIA para o sync. Formato:
# https://b24-XXXX.bitrix24.com.br/rest/{user}/{token}/
BITRIX_WEBHOOK_URL=
# RESERVADA / OPCIONAL: token do webhook de SAÍDA do Bitrix (eventos ONCRMDEAL*/
# ONCRMLEAD*). Não usada por ora (sem webhook de saída). Só necessária se/quando
# a rota /api/webhooks/bitrix for ativada.
# BITRIX_OUTBOUND_TOKEN=

# --- Segredo compartilhado das rotas de sync (Fases 2 e 3) ---
# Protege /api/sync/* (backfill, reconcile, sheets).
SYNC_SECRET=

# --- Webhooks / Integrações ---
# Chave-mestra AES-256-GCM (32 bytes em base64) para segredos reversíveis:
# assinatura HMAC dos webhooks de saída e futuros conectores de pull.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KEY_ENCRYPTION_KEY=

# --- Google Sheets (Fase 3, Opção B — leitura direta; atrás de flag) ---
# Deixe em branco enquanto usar a Opção A (push via Apps Script).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
SHEET_ID_ESTUDO_FECHAMENTOS=
SHEET_ID_INBOUND_ZAPPER=

# --- Owner (multi-org, 0089) ---
# uid (auth.users.id) do ÚNICO usuário autorizado no modo Owner (/owner —
# criar/excluir organizações). Junto com a linha em app_owner (seed 0089),
# forma a dupla checagem do guard fail-closed (lib/auth/owner.ts): ausente ⇒
# o modo Owner NEGA sempre.
OWNER_USER_ID=
